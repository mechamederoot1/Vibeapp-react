{
  "name": "vibe-social",
  "version": "1.0.0",
  "description": "Rede social moderna e responsiva",
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python3 main.py",
    "install:all": "npm run install:frontend && npm run install:backend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && python3 -m pip install -r requirements.txt",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm run preview",
    "build:mobile": "cd frontend && npm run build:mobile",
    "android": "cd frontend && npm run android",
    "ios": "cd frontend && npm run ios",
    "sync": "cd frontend && npm run sync"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend"
  ]
}